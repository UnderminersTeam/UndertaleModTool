                        Text="Script progress"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        x:Name="ScriptProgressValueText"
                        Grid.Column="1"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="0/0" />
                </Grid>
                <ProgressBar
                    x:Name="ScriptProgressBar"
                    Maximum="1"
                    Minimum="0"
                    Value="0" />
                <TextBlock
                    x:Name="ScriptProgressStatusText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>
            <Grid
                Grid.Row="1"
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="CommandBox"
                    AcceptsReturn="False"
                    Header="Command"
                    IsEnabled="False"
                    IsSpellCheckEnabled="False"
                    IsTextPredictionEnabled="False"
                    MaxHeight="84"
                    MinHeight="36"
                    PlaceholderText="Run C# script command"
                    TextChanged="CommandBox_TextChanged"
                    TextWrapping="Wrap" />
                <Button
                    x:Name="CommandRunButton"
                    Grid.Column="1"
                    MinWidth="84"
                    VerticalAlignment="Bottom"
                    Click="CommandRunButton_Click"
                    IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Play" />
                        <TextBlock Text="Run" />
                    </StackPanel>
                    <ToolTipService.ToolTip>Run command</ToolTipService.ToolTip>
                </Button>
            </Grid>
            <Grid Grid.Row="2" RowSpacing="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    FontSize="12"
                    Foreground="{StaticResource WinUiQuietTextBrush}"
                    Text="Load status" />
                <Border
                    Grid.Row="1"
                    Background="{StaticResource WinUiHeaderBackgroundBrush}"
                    BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    MinHeight="42"
                    MaxHeight="82"
                    Padding="10,3">
                    <Grid
                        MinHeight="34"
                        ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Background="{StaticResource WinUiIconWellBrush}"
                            CornerRadius="5">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="12"
                                Foreground="{StaticResource WinUiQuietTextBrush}"
                                Glyph="&#xE946;" />
                        </Border>
                        <ScrollViewer
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <TextBlock
                                x:Name="StatusBox"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{StaticResource WinUiQuietTextBrush}"
                                LineHeight="16"
                                Margin="0,0,0,1"
                                Text="Ready."
                                TextWrapping="WrapWholeWords" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
