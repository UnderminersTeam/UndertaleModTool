                                <SelectorBarItem x:Name="FramesTab" Text="Frames" />
                                <SelectorBarItem x:Name="CollisionTab" Text="Collision" />
                                <SelectorBarItem x:Name="ExportTab" Text="Export" />
                            </SelectorBar>

                            <!-- Tab Contents -->
