                                <!-- Overview Tab Content -->
                                <ScrollViewer x:Name="SpriteOverviewTabPanel" VerticalScrollBarVisibility="Auto" Padding="0,0,0,0" Visibility="Collapsed">
                                    <StackPanel Spacing="16">
                                        <Border
                                            Padding="16"
                                            Background="{StaticResource WinUiPanelBackgroundAltBrush}"
                                            BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
