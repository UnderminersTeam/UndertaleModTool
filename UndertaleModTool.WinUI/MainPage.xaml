<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="UndertaleModTool_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UndertaleModTool_WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        Padding="16,10,16,12"
        Background="{StaticResource WinUiShellBackgroundBrush}"
        RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <MenuBar>
                <MenuBarItem Title="File">
                    <MenuFlyoutItem
                        x:Name="NewDataFileMenuItem"
                        Click="NewDataFileMenuItem_Click"
                        KeyboardAcceleratorTextOverride="Ctrl+N"
                        Text="New data file" />
                    <MenuFlyoutItem
                        x:Name="OpenMenuItem"
                        Click="OpenButton_Click"
                        KeyboardAcceleratorTextOverride="Ctrl+O"
                        Text="Open data file" />
                    <MenuFlyoutSubItem
                        x:Name="OpenRecentMenuItem"
                        IsEnabled="False"
                        Text="Open recent" />
                    <MenuFlyoutItem
                        x:Name="SaveMenuItem"
                        Click="SaveButton_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Ctrl+S"
                        Text="Save" />
                    <MenuFlyoutItem
                        x:Name="SaveAsMenuItem"
                        Click="SaveAsButton_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Ctrl+Shift+S"
                        Text="Save as" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        x:Name="TempRunGameMenuItem"
                        Click="TempRunGameMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="F5"
                        Text="Temp run game" />
                    <MenuFlyoutItem
                        x:Name="RunWithOtherRunnerMenuItem"
                        Click="RunWithOtherRunnerMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Alt+F5"
                        Text="Run game with other runner" />
                    <MenuFlyoutItem
                        x:Name="RunGmsDebuggerMenuItem"
                        Click="RunGmsDebuggerMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Shift+F5"
                        Text="Run game under GMS debugger" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        x:Name="GenerateOffsetMapMenuItem"
                        Click="GenerateOffsetMapMenuItem_Click"
                        Text="Generate offset map" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        x:Name="SettingsMenuItem"
                        Click="SettingsMenuItem_Click"
                        Text="Settings" />
                    <MenuFlyoutItem
                        x:Name="CloseWindowMenuItem"
                        Click="CloseWindowMenuItem_Click"
                        KeyboardAcceleratorTextOverride="Ctrl+Q"
                        Text="Close" />
                </MenuBarItem>
                <MenuBarItem Title="Find">
                    <MenuFlyoutItem
                        x:Name="FindResourceMenuItem"
                        Click="FindResourceMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Ctrl+F"
                        Text="Filter resources" />
                    <MenuFlyoutItem
                        x:Name="FindCodeMenuItem"
                        Click="FindCodeMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Ctrl+Shift+F"
                        Text="Search all code" />
                    <MenuFlyoutItem
                        x:Name="FindStringsMenuItem"
                        Click="FindStringsMenuItem_Click"
                        IsEnabled="False"
                        Text="Search strings" />
                    <MenuFlyoutItem
                        x:Name="FindUnreferencedAssetsMenuItem"
                        Click="FindUnreferencedAssetsMenuItem_Click"
                        IsEnabled="False"
                        Text="Find unreferenced assets" />
                </MenuBarItem>
                <MenuBarItem Title="View">
                    <MenuFlyoutItem
                        x:Name="BackNavigationMenuItem"
                        Click="BackNavigationMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Alt+Left"
                        Text="Back" />
                    <MenuFlyoutItem
                        x:Name="ForwardNavigationMenuItem"
                        Click="ForwardNavigationMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Alt+Right"
                        Text="Forward" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        x:Name="PreviousTabMenuItem"
                        Click="PreviousTabMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Ctrl+Shift+Tab"
                        Text="Previous tab" />
                    <MenuFlyoutItem
                        x:Name="NextTabMenuItem"
                        Click="NextTabMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Ctrl+Tab"
                        Text="Next tab" />
                    <MenuFlyoutItem
                        x:Name="CloseTabMenuItem"
                        Click="CloseTabMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Ctrl+W"
                        Text="Close tab" />
                    <MenuFlyoutItem
                        x:Name="CloseAllTabsMenuItem"
                        Click="CloseAllTabsMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Ctrl+Shift+W"
                        Text="Close all tabs" />
                    <MenuFlyoutItem
                        x:Name="RestoreClosedTabMenuItem"
                        Click="RestoreClosedTabMenuItem_Click"
                        IsEnabled="False"
                        KeyboardAcceleratorTextOverride="Ctrl+Shift+T"
                        Text="Restore closed tab" />
                </MenuBarItem>
                <MenuBarItem
                    x:Name="ScriptsMenuItem"
                    Title="Scripts" />
                <MenuBarItem Title="Project">
                    <MenuFlyoutItem
                        x:Name="NewProjectMenuItem"
                        Click="NewProjectMenuItem_Click"
                        Text="New project" />
                    <MenuFlyoutItem
                        x:Name="OpenProjectMenuItem"
                        Click="OpenProjectMenuItem_Click"
                        Text="Open project" />
                    <MenuFlyoutItem
                        x:Name="SaveProjectMenuItem"
                        Click="SaveProjectMenuItem_Click"
                        IsEnabled="False"
                        Text="Save project" />
                    <MenuFlyoutItem
                        x:Name="ViewProjectAssetsMenuItem"
                        Click="ViewProjectAssetsMenuItem_Click"
                        IsEnabled="False"
                        Text="View unexported assets" />
                    <MenuFlyoutItem
                        x:Name="CloseProjectMenuItem"
                        Click="CloseProjectMenuItem_Click"
                        IsEnabled="False"
                        Text="Close project" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        x:Name="ExportAllCodeMenuItem"
                        Click="ExportAllCodeButton_Click"
                        IsEnabled="False"
                        Text="Export all code" />
                    <MenuFlyoutItem
                        x:Name="ExportStringsMenuItem"
                        Click="ExportStringsButton_Click"
                        IsEnabled="False"
                        Text="Export strings JSON" />
                    <MenuFlyoutItem
                        x:Name="ImportStringsMenuItemMenu"
                        Click="ImportStringsButton_Click"
                        IsEnabled="False"
                        Text="Import strings JSON" />
                </MenuBarItem>
                <MenuBarItem Title="Help">
                    <MenuFlyoutItem
                        Click="GitHubMenuItem_Click"
                        Text="GitHub" />
                    <MenuFlyoutItem
                        Click="AboutMenuItem_Click"
                        Text="About" />
                </MenuBarItem>
            </MenuBar>

            <Border
                Padding="0,6,0,2"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="0">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="ResourceBackButton"
                        Click="ResourceBackButton_Click"
                        IsEnabled="False"
                        MinHeight="34"
                        MinWidth="36"
                        Padding="8,6" />

                    <Button
                        x:Name="ResourceForwardButton"
                        Grid.Column="1"
                        Click="ResourceForwardButton_Click"
                        IsEnabled="False"
                        MinHeight="34"
                        MinWidth="36"
                        Padding="8,6" />

                    <Button
                        x:Name="OpenButton"
                        Grid.Column="2"
                        Click="OpenButton_Click"
                        MinHeight="34"
                        Padding="13,6" />

                    <Button
                        x:Name="SaveButton"
                        Grid.Column="3"
                        Click="SaveButton_Click"
                        IsEnabled="False"
                        MinHeight="34"
                        Padding="13,6" />

                    <Button
                        x:Name="SaveAsButton"
                        Grid.Column="4"
                        Click="SaveAsButton_Click"
                        IsEnabled="False"
                        MinHeight="34"
                        Padding="13,6" />

                    <Border
                        Grid.Column="5"
                        Width="1"
                        Height="32"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{StaticResource WinUiPanelStrokeBrush}"
                        Opacity="0.62" />

                    <Grid
                        Grid.Column="6"
                        VerticalAlignment="Center"
                        ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="1"
                            MinHeight="36"
                            Background="{StaticResource WinUiPanelStrokeBrush}"
                            CornerRadius="2"
                            Opacity="0.82" />
                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock
                                x:Name="GameTitleText"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="No game loaded" />
                            <TextBlock
                                x:Name="FilePathText"
                                Foreground="{StaticResource WinUiQuietTextBrush}"
                                Text="Open a GameMaker data file to browse resources."
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <ProgressRing
                            x:Name="LoadProgressRing"
                            Grid.Column="2"
                            Width="22"
                            Height="22"
                            Margin="8,0,0,0"
                            IsActive="False"
                            Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>

        <Grid
            x:Name="BrowserGrid"
            Grid.Row="1"
            ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="CategoryColumn" Width="270" />
                <ColumnDefinition x:Name="ResourceItemsColumn" Width="280" />
                <ColumnDefinition x:Name="DetailsColumn" Width="*" />
                <ColumnDefinition x:Name="RecentColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="8"
                Background="{StaticResource WinUiPanelBackgroundBrush}"
                BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <ListView
                    x:Name="CategoryList"
                    Header="Resources"
                    IsItemClickEnabled="True"
                    ItemClick="CategoryList_ItemClick"
                    ScrollViewer.VerticalScrollBarVisibility="Visible"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                MinHeight="38"
                                Padding="7,5"
                                CornerRadius="5">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="22"
                                        Height="22"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource WinUiIconWellBrush}"
                                        CornerRadius="5"
                                        Opacity="0.72">
                                        <SymbolIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource WinUiQuietTextBrush}"
                                            Symbol="{Binding IconSymbol}" />
                                    </Border>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{Binding Label}"
                                        TextTrimming="CharacterEllipsis" />
                                    <Border
                                        Grid.Column="2"
                                        MinWidth="42"
                                        Padding="8,2"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource WinUiPanelBackgroundAltBrush}"
                                        BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource WinUiQuietTextBrush}"
                                            Text="{Binding CountText}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Border
                x:Name="ResourceItemsPane"
                Grid.Column="1"
                Padding="10,8,8,8"
                Background="{StaticResource WinUiPanelBackgroundBrush}"
                BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <Grid
                    x:Name="ResourceItemsPanel"
                    RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="ResourceFilterBox"
                            Header="Items"
                            IsEnabled="False"
                            KeyDown="ResourceFilterBox_KeyDown"
                            PlaceholderText="Filter resources"
                            TextChanged="ResourceFilterBox_TextChanged" />
                        <Button
                            x:Name="AddResourceButton"
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Click="AddResourceButton_Click"
                            IsEnabled="False">
                            <SymbolIcon Symbol="Add" />
                            <ToolTipService.ToolTip>Add resource</ToolTipService.ToolTip>
                        </Button>
                        <Button
                            x:Name="DuplicateStringButton"
                            Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Click="DuplicateStringButton_Click"
                            IsEnabled="False">
                            <SymbolIcon Symbol="Copy" />
                        </Button>
                    </Grid>

                    <ListView
                        x:Name="ResourceList"
                        Grid.Row="1"
                        AllowDrop="True"
                        CanDragItems="True"
                        DragItemsStarting="ResourceList_DragItemsStarting"
                        DragOver="ResourceList_DragOver"
                        Drop="ResourceList_Drop"
                        IsItemClickEnabled="True"
                        ItemClick="ResourceList_ItemClick"
                        KeyDown="ResourceList_KeyDown"
                        ScrollViewer.VerticalScrollBarVisibility="Visible"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    MinHeight="48"
                                    Padding="8,6"
                                    CornerRadius="6"
                                    RightTapped="ResourceItemBorder_RightTapped">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="22"
                                            Height="22"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource WinUiIconWellBrush}"
                                            CornerRadius="5"
                                            Opacity="0.82">
                                            <SymbolIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource WinUiQuietTextBrush}"
                                                Symbol="{Binding IconSymbol}" />
                                        </Border>
                                        <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="1">
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{Binding Title}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource WinUiMutedTextBrush}"
                                                Text="{Binding Subtitle}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock
                        x:Name="ResourceListFooterText"
                        Grid.Row="2"
                        Margin="6,2,6,0"
                        FontSize="12"
                        Foreground="{StaticResource WinUiMutedTextBrush}"
                        Text="No items"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>

            <ScrollViewer
                x:Name="DetailsScrollViewer"
                Grid.Column="2"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <Border
                    Padding="10"
                    Background="{StaticResource WinUiPanelBackgroundBrush}"
                    BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel Spacing="10">
                    <TabView
                        x:Name="OpenResourceTabsList"
                        CanDragTabs="False"
                        CanReorderTabs="False"
                        IsAddTabButtonVisible="False"
                        MaxHeight="52"
                        SelectionChanged="OpenResourceTabsList_SelectionChanged"
                        TabCloseRequested="OpenResourceTabsList_TabCloseRequested"
                        Visibility="Collapsed">
                        <TabView.TabItemTemplate>
                            <DataTemplate>
                                <TabViewItem IsClosable="True">
                                    <TabViewItem.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                Click="CloseTabContextMenuItem_Click"
                                                CommandParameter="{Binding}"
                                                Text="Close" />
                                            <MenuFlyoutItem
                                                Click="CloseOtherTabsContextMenuItem_Click"
                                                CommandParameter="{Binding}"
                                                Text="Close other tabs" />
                                            <MenuFlyoutItem
                                                Click="CloseAllTabsContextMenuItem_Click"
                                                Text="Close all tabs" />
                                        </MenuFlyout>
                                    </TabViewItem.ContextFlyout>
                                    <TabViewItem.Header>
                                        <Grid
                                            MinWidth="132"
                                            MaxWidth="188"
                                            ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Width="20"
                                                Height="20"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource WinUiIconWellBrush}"
                                                CornerRadius="5"
                                                Opacity="0.86">
                                                <SymbolIcon
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource WinUiQuietTextBrush}"
                                                    Symbol="{Binding IconSymbol}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Title}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{StaticResource WinUiMutedTextBrush}"
                                                    Text="{Binding CategoryLabel}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </TabViewItem.Header>
                                </TabViewItem>
                            </DataTemplate>
                        </TabView.TabItemTemplate>
                    </TabView>

                    <Border
                        x:Name="ProjectExportPanel"
                        Padding="10,8"
                        Background="{StaticResource WinUiCardBackgroundBrush}"
                        BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="Collapsed">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="Marked for project export" />
                                <TextBlock
                                    x:Name="ProjectExportDescriptionText"
                                    FontSize="12"
                                    Foreground="{StaticResource WinUiMutedTextBrush}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <CheckBox
                                x:Name="ProjectExportCheckBox"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Checked="ProjectExportCheckBox_Changed"
                                Unchecked="ProjectExportCheckBox_Changed" />
                        </Grid>
                    </Border>

                    <Expander
                        x:Name="GlobalToolsExpander"
                        Header="Search and export"
                        IsExpanded="False"
                        Visibility="Collapsed">
                        <StackPanel Spacing="8">
                            <StackPanel
                                x:Name="GlobalCodeToolsPanel"
                                Spacing="8"
                                Visibility="Collapsed">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="GlobalCodeSearchBox"
                                        Header="Search all code"
                                        PlaceholderText="Text to find" />
                                    <ComboBox
                                        x:Name="GlobalCodeSearchModeBox"
                                        Grid.Column="1"
                                        Header="Mode"
                                        SelectedIndex="0">
                                        <ComboBoxItem Content="Disassembly" />
                                        <ComboBoxItem Content="Decompiled" />
                                    </ComboBox>
                                    <Button
                                        x:Name="GlobalCodeSearchButton"
                                        Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Click="GlobalCodeSearchButton_Click"
                                        Content="Search" />
                                    <Button
                                        x:Name="ExportAllCodeButton"
                                        Grid.Column="3"
                                        VerticalAlignment="Bottom"
                                        Click="ExportAllCodeButton_Click"
                                        Content="Export all" />
                                </Grid>

                                <ListView
                                    x:Name="GlobalCodeSearchResultsList"
                                    IsItemClickEnabled="True"
                                    ItemClick="GlobalCodeSearchResultsList_ItemClick"
                                    MaxHeight="180"
                                    SelectionMode="Single">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Padding="0,6">
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Title}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding Preview}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>

                            <StackPanel
                                x:Name="GlobalStringToolsPanel"
                                Spacing="8"
                                Visibility="Collapsed">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="GlobalStringSearchBox"
                                        Header="Search strings"
                                        PlaceholderText="Text to find" />
                                    <Button
                                        x:Name="GlobalStringSearchButton"
                                        Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Click="GlobalStringSearchButton_Click"
                                        Content="Search" />
                                    <Button
                                        x:Name="ExportStringsButton"
                                        Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Click="ExportStringsButton_Click"
                                        Content="Export all" />
                                    <Button
                                        x:Name="ImportStringsButton"
                                        Grid.Column="3"
                                        VerticalAlignment="Bottom"
                                        Click="ImportStringsButton_Click"
                                        Content="Import JSON" />
                                </Grid>

                                <ListView
                                    x:Name="GlobalStringSearchResultsList"
                                    IsItemClickEnabled="True"
                                    ItemClick="GlobalStringSearchResultsList_ItemClick"
                                    MaxHeight="160"
                                    SelectionMode="Single">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Padding="0,6">
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Title}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding Preview}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Grid
                        x:Name="NoDataEmptyStatePanel"
                        MinHeight="520"
                        Padding="34,18,34,30"
                        Visibility="Collapsed">
                        <Grid
                            MaxWidth="760"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RowSpacing="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                HorizontalAlignment="Center"
                                Spacing="10">
                                <Border
                                    Width="56"
                                    Height="56"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource WinUiPanelBackgroundAltBrush}"
                                    BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Opacity="0.88">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="24"
                                        Foreground="{StaticResource WinUiQuietTextBrush}"
                                        Glyph="&#xE8E5;" />
                                </Border>
                                <StackPanel Spacing="5">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="24"
                                        FontWeight="SemiBold"
                                        Text="No game loaded" />
                                    <TextBlock
                                        MaxWidth="460"
                                        HorizontalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        LineHeight="20"
                                        Text="Open a GameMaker data file to begin."
                                        TextAlignment="Center"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                Spacing="8">
                                <Button
                                    HorizontalAlignment="Center"
                                    Click="OpenButton_Click"
                                    Padding="18,9">
                                    <StackPanel Orientation="Horizontal" Spacing="9">
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="14"
                                            Glyph="&#xE8E5;" />
                                        <TextBlock Text="Open data file" />
                                    </StackPanel>
                                </Button>

                                <Grid
                                    Width="440"
                                    ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Height="1"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource ControlStrokeColorDefaultBrush}"
