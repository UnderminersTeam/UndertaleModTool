                                                <TextBlock x:Name="OverviewSpriteNameText" FontSize="20" FontWeight="Bold" Text="spr_undertaletitle" />
                                                <TextBlock Text="Sprite Asset Overview" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            </StackPanel>
                                        </Border>

                                        <Grid ColumnSpacing="12" RowSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Grid.Column="0" Padding="14" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Dimensions" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock x:Name="OverviewDimensionsText" FontSize="16" FontWeight="SemiBold" Text="320 x 240 px"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="0" Grid.Column="1" Padding="14" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Frames" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock x:Name="OverviewFramesCountText" FontSize="16" FontWeight="SemiBold" Text="1 frame"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="0" Grid.Column="2" Padding="14" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Origin" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock x:Name="OverviewOriginText" FontSize="16" FontWeight="SemiBold" Text="(0, 0)"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1" Grid.Column="0" Padding="14" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Collision Masks" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock x:Name="OverviewCollisionCountText" FontSize="16" FontWeight="SemiBold" Text="1 mask"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1" Grid.Column="1" Padding="14" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Type" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock x:Name="OverviewTypeText" FontSize="16" FontWeight="SemiBold" Text="Normal"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Metadata Tab Content -->
                                <ScrollViewer x:Name="SpriteMetadataTabPanel" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,0" Visibility="Visible">
                                    <Grid ColumnSpacing="8" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Column 0 Cards -->
                                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="8">
                                            <Border Padding="10" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="7">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{StaticResource WinUiQuietTextBrush}" Glyph="&#xEB9F;" />
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Dimensions &amp; Layout" />
                                                    </StackPanel>
                                                    <TextBox
                                                        x:Name="SpriteNameBox"
                                                        Header="Name"
                                                        KeyDown="SpriteNameBox_KeyDown"
                                                        LostFocus="SpriteNameBox_LostFocus" />
                                                    <Grid ColumnSpacing="8" RowSpacing="6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <TextBox x:Name="SpriteWidthBox" Grid.Row="0" Grid.Column="0" Header="Width" Tag="Width" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <TextBox x:Name="SpriteMarginTopBox" Grid.Row="0" Grid.Column="1" Header="Margin Top" Tag="MarginTop" LostFocus="SpritePropertyBox_LostFocus" />

                                                        <TextBox x:Name="SpriteHeightBox" Grid.Row="1" Grid.Column="0" Header="Height" Tag="Height" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <TextBox x:Name="SpriteMarginBottomBox" Grid.Row="1" Grid.Column="1" Header="Margin Bottom" Tag="MarginBottom" LostFocus="SpritePropertyBox_LostFocus" />

                                                        <TextBox x:Name="SpriteMarginLeftBox" Grid.Row="2" Grid.Column="0" Header="Margin Left" Tag="MarginLeft" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <ComboBox x:Name="SpriteTransparentBox" Grid.Row="2" Grid.Column="1" Header="Transparent" Tag="Transparent" SelectionChanged="SpriteComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="False" />
                                                            <ComboBoxItem Content="True" />
                                                        </ComboBox>

                                                        <TextBox x:Name="SpriteMarginRightBox" Grid.Row="3" Grid.Column="0" Header="Margin Right" Tag="MarginRight" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <ComboBox x:Name="SpriteSmoothBox" Grid.Row="3" Grid.Column="1" Header="Smooth" Tag="Smooth" SelectionChanged="SpriteComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="False" />
                                                            <ComboBoxItem Content="True" />
                                                        </ComboBox>

                                                        <CheckBox x:Name="SpritePreloadBox" Grid.Row="4" Grid.Column="0" Content="Preload" Tag="Preload" Checked="SpriteCheckBox_Changed" Unchecked="SpriteCheckBox_Changed" Margin="0,8,0,0"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="0" Grid.Row="1" Spacing="8">
                                            <Border Padding="10" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="7">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{StaticResource WinUiQuietTextBrush}" Glyph="&#xE768;" />
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Playback &amp; Timing" />
                                                    </StackPanel>
                                                    <StackPanel Spacing="8">
                                                        <TextBox x:Name="SpriteGMS2PlaybackSpeedBox" Header="GMS2 Playback Speed" Tag="GMS2PlaybackSpeed" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <ComboBox x:Name="SpriteGMS2PlaybackSpeedTypeBox" Header="Playback Speed Type" Tag="GMS2PlaybackSpeedType" SelectionChanged="SpriteComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="FramesPerSecond" />
                                                            <ComboBoxItem Content="FramesPerGameFrame" />
                                                        </ComboBox>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- Column 1 Cards -->
                                        <StackPanel Grid.Column="1" Grid.Row="0" Spacing="8">
                                            <Border Padding="10" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="7">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{StaticResource WinUiQuietTextBrush}" Glyph="&#xE707;" />
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Origin &amp; Alignment" />
                                                    </StackPanel>
                                                    <Grid ColumnSpacing="8" RowSpacing="6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <TextBox x:Name="SpriteOriginXBox" Grid.Row="0" Grid.Column="0" Header="Origin X" Tag="OriginX" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <TextBox x:Name="SpriteOriginYBox" Grid.Row="0" Grid.Column="1" Header="Origin Y" Tag="OriginY" LostFocus="SpritePropertyBox_LostFocus" />

                                                        <TextBox x:Name="SpriteOriginXWrapperBox" Grid.Row="1" Grid.Column="0" Header="Origin X Wrapper" Tag="OriginXWrapper" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <TextBox x:Name="SpriteOriginYWrapperBox" Grid.Row="1" Grid.Column="1" Header="Origin Y Wrapper" Tag="OriginYWrapper" LostFocus="SpritePropertyBox_LostFocus" />

                                                        <ComboBox x:Name="SpriteSepMasksBox" Grid.Row="2" Grid.ColumnSpan="2" Header="SepMasks" Tag="SepMasks" SelectionChanged="SpriteComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="AxisAlignedRect" />
                                                            <ComboBoxItem Content="Precise" />
                                                            <ComboBoxItem Content="RotatedRect" />
                                                        </ComboBox>

                                                        <TextBox x:Name="SpriteBBoxModeBox" Grid.Row="3" Grid.ColumnSpan="2" Header="BBoxMode" Tag="BBoxMode" LostFocus="SpritePropertyBox_LostFocus" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Grid.Row="1" Spacing="8">
                                            <Border Padding="10" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="7">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{StaticResource WinUiQuietTextBrush}" Glyph="&#xE895;" />
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Versioning &amp; Spine" />
                                                    </StackPanel>
                                                    <Grid ColumnSpacing="8" RowSpacing="6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <TextBox x:Name="SpriteSpineVersionBox" Grid.Row="0" Grid.Column="0" Header="Spine Version" Tag="SpineVersion" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <TextBox x:Name="SpriteSpineCacheVersionBox" Grid.Row="0" Grid.Column="1" Header="Cache Version" Tag="SpineCacheVersion" LostFocus="SpritePropertyBox_LostFocus" />

                                                        <TextBox x:Name="SpriteSpineJSONBox" Grid.Row="1" Grid.Column="0" Header="Spine JSON" Tag="SpineJSON" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <TextBox x:Name="SpriteSpineAtlasBox" Grid.Row="1" Grid.Column="1" Header="Spine Atlas" Tag="SpineAtlas" LostFocus="SpritePropertyBox_LostFocus" />

                                                        <TextBox x:Name="SpriteSWFVersionBox" Grid.Row="2" Grid.Column="0" Header="SWF Version" Tag="SWFVersion" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <TextBox x:Name="SpriteVectorVersionBox" Grid.Row="2" Grid.Column="1" Header="Vector Version" Tag="VectorVersion" LostFocus="SpritePropertyBox_LostFocus" />

                                                        <TextBox x:Name="SpriteSVersionBox" Grid.Row="3" Grid.ColumnSpan="2" Header="Sprite SVersion" Tag="SVersion" LostFocus="SpritePropertyBox_LostFocus" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Grid.Row="0" Spacing="8">
                                            <Border Padding="10" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="7">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{StaticResource WinUiQuietTextBrush}" Glyph="&#xE8B9;" />
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Texture &amp; Rendering" />
                                                    </StackPanel>
                                                    <StackPanel Spacing="7">
                                                        <TextBox x:Name="SpriteTexturePageItemBox" Header="Texture Page Item" IsReadOnly="True" />
                                                        <TextBox x:Name="SpriteTextureInfoText" Header="Texture Info" IsReadOnly="True" />
                                                        <ComboBox x:Name="SpriteBlendModeBox" Header="Blend Mode" HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="Normal" />
                                                            <ComboBoxItem Content="Additive" />
                                                            <ComboBoxItem Content="Subtracted" />
                                                        </ComboBox>
                                                        <ComboBox x:Name="SpriteIsSpecialTypeBox" Header="Is Special Type" Tag="IsSpecialType" SelectionChanged="SpriteComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="False" />
                                                            <ComboBoxItem Content="True" />
                                                        </ComboBox>
                                                        <ComboBox x:Name="SpriteSSpriteTypeBox" Header="SSpriteType" Tag="SSpriteType" SelectionChanged="SpriteComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="Normal" />
                                                            <ComboBoxItem Content="SWF" />
                                                            <ComboBoxItem Content="Spine" />
                                                            <ComboBoxItem Content="Vector" />
                                                        </ComboBox>
                                                        <ComboBox x:Name="SpriteSpineHasTextureDataBox" Header="Spine Has Texture Data" Tag="SpineHasTextureData" SelectionChanged="SpriteComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                                            <ComboBoxItem Content="False" />
                                                            <ComboBoxItem Content="True" />
                                                        </ComboBox>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Grid.Row="1" Spacing="8">
                                            <Border Padding="10" Background="{StaticResource WinUiPanelBackgroundAltBrush}" BorderBrush="{StaticResource WinUiPanelStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                                <StackPanel Spacing="7">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{StaticResource WinUiQuietTextBrush}" Glyph="&#xE713;" />
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Advanced Flags &amp; Data" />
                                                    </StackPanel>
                                                    <StackPanel Spacing="7">
                                                        <TextBox x:Name="SpriteVectorCollisionMaskWidthBox" Header="Vector Mask Width" Tag="VectorCollisionMaskWidth" LostFocus="SpritePropertyBox_LostFocus" />
                                                        <TextBox x:Name="SpriteVectorCollisionMaskHeightBox" Header="Vector Mask Height" Tag="VectorCollisionMaskHeight" LostFocus="SpritePropertyBox_LostFocus" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                    </Grid>
                                </ScrollViewer>

                                <!-- Preview Tab Content -->
                                <ScrollViewer x:Name="SpritePreviewTabPanel" VerticalScrollBarVisibility="Auto" Padding="0,0,0,0" Visibility="Collapsed">
                                    <Grid ColumnSpacing="12" RowSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Padding="16"
                                            Background="{StaticResource WinUiPanelBackgroundAltBrush}"
                                            BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel Spacing="12">
                                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Sprite preview" />
                                                <Border
                                                    MinHeight="360"
                                                    Background="{StaticResource WinUiPanelBackgroundBrush}"
                                                    BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10">
                                                    <Image
                                                        x:Name="SpriteLargePreviewImage"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        MaxHeight="520"
                                                        Stretch="Uniform"
                                                        Tapped="PreviewImage_Tapped"
                                                        ToolTipService.ToolTip="Open full preview" />
                                                </Border>
                                                <TextBlock
                                                    x:Name="SpriteLargePreviewInfoText"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Padding="16"
                                            Background="{StaticResource WinUiPanelBackgroundAltBrush}"
                                            BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel Spacing="12">
                                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Frame" />
                                                <ComboBox
                                                    HorizontalAlignment="Stretch"
                                                    ItemsSource="{Binding ElementName=SpriteFrameComboBox, Path=ItemsSource}"
                                                    SelectedIndex="{Binding ElementName=SpriteFrameComboBox, Path=SelectedIndex, Mode=TwoWay}" />
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button
                                                        x:Name="SpriteLargeFramePrevButton"
                                                        HorizontalAlignment="Stretch"
                                                        Click="SpriteFramePrevButton_Click"
                                                        Content="Previous" />
                                                    <Button
                                                        x:Name="SpriteLargeFrameNextButton"
                                                        Grid.Column="1"
                                                        HorizontalAlignment="Stretch"
                                                        Click="SpriteFrameNextButton_Click"
                                                        Content="Next" />
                                                </Grid>
                                                <Border Height="1" Background="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                                <Button
                                                    x:Name="SpriteOpenTextureButton"
                                                    HorizontalAlignment="Stretch"
                                                    Click="SpriteOpenTextureButton_Click"
                                                    Content="Open Texture Page Item" />
                                                <Button
                                                    HorizontalAlignment="Stretch"
                                                    Click="SpriteOpenTextureButton_Click"
                                                    Content="Open Selected Texture"
                                                    IsEnabled="{Binding ElementName=SpriteOpenTextureButton, Path=IsEnabled}" />
                                                <Button
                                                    HorizontalAlignment="Stretch"
                                                    Click="SpriteExportFrameButton_Click"
                                                    Content="Export Frame..."
                                                    IsEnabled="{Binding ElementName=SpriteExportFrameButton, Path=IsEnabled}" />
                                                <Button
                                                    HorizontalAlignment="Stretch"
                                                    Click="SpriteExportAllButton_Click"
                                                    Content="Export All..."
                                                    IsEnabled="{Binding ElementName=SpriteExportAllButton, Path=IsEnabled}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </ScrollViewer>

                                <!-- Frames Tab Content -->
                                <ScrollViewer x:Name="SpriteFramesTabPanel" VerticalScrollBarVisibility="Auto" Padding="0,0,0,0" Visibility="Collapsed">
                                    <Grid ColumnSpacing="12" RowSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Padding="16"
                                            Background="{StaticResource WinUiPanelBackgroundAltBrush}"
                                            BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel Spacing="12">
                                                <StackPanel Spacing="2">
                                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Frames" />
                                                    <TextBlock
                                                        x:Name="SpriteFramesSummaryText"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="Texture frames in this sprite." />
                                                </StackPanel>
                                                <ListView
                                                    x:Name="SpriteTexturesList"
                                                    IsItemClickEnabled="True"
                                                    ItemClick="SpriteTexturesList_ItemClick"
                                                    MaxHeight="460"
                                                    SelectionMode="Single">
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Padding="0,6" ColumnSpacing="10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="26" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border
                                                                    Width="24"
                                                                    Height="24"
                                                                    Background="{StaticResource WinUiPanelBackgroundBrush}"
                                                                    BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4">
                                                                    <SymbolIcon Symbol="Pictures" />
                                                                </Border>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Padding="16"
                                            Background="{StaticResource WinUiPanelBackgroundAltBrush}"
                                            BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel Spacing="12">
                                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Frame actions" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="Selected frame actions."
                                                    TextWrapping="Wrap" />
                                                <Button
                                                    HorizontalAlignment="Stretch"
                                                    Click="SpriteExportFrameButton_Click"
                                                    Content="Export Frame..."
                                                    IsEnabled="{Binding ElementName=SpriteExportFrameButton, Path=IsEnabled}" />
                                                <Button
                                                    HorizontalAlignment="Stretch"
                                                    Click="SpriteExportAllButton_Click"
                                                    Content="Export All..."
                                                    IsEnabled="{Binding ElementName=SpriteExportAllButton, Path=IsEnabled}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </ScrollViewer>

                                <!-- Collision Tab Content -->
                                <ScrollViewer x:Name="SpriteCollisionTabPanel" VerticalScrollBarVisibility="Auto" Padding="0,0,0,0" Visibility="Collapsed">
                                    <Grid ColumnSpacing="12" RowSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Padding="16"
                                            Background="{StaticResource WinUiPanelBackgroundAltBrush}"
                                            BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel Spacing="12">
                                                <StackPanel Spacing="2">
                                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Collision masks" />
                                                    <TextBlock
                                                        x:Name="SpriteCollisionSummaryText"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="Masks attached to this sprite." />
                                                </StackPanel>
                                                <ListView
                                                    x:Name="SpriteMasksList"
                                                    IsItemClickEnabled="True"
                                                    ItemClick="SpriteMasksList_ItemClick"
                                                    MaxHeight="420"
                                                    SelectionMode="Single">
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Padding="0,6" ColumnSpacing="10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="26" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border
                                                                    Width="24"
                                                                    Height="24"
                                                                    Background="{StaticResource WinUiPanelBackgroundBrush}"
                                                                    BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4">
                                                                    <SymbolIcon Symbol="Flag" />
                                                                </Border>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Padding="16"
                                            Background="{StaticResource WinUiPanelBackgroundAltBrush}"
                                            BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel Spacing="10">
                                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Collision summary" />
                                                <Grid RowSpacing="8" ColumnSpacing="16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Mode" />
                                                    <TextBlock x:Name="SpriteCollisionModeText" Grid.Column="1" FontWeight="SemiBold" Text="-" />
                                                    <TextBlock Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Bounding box" />
                                                    <TextBlock x:Name="SpriteCollisionBoundsText" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" Text="-" />
                                                    <TextBlock Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Mask count" />
                                                    <TextBlock x:Name="SpriteCollisionCountText" Grid.Row="2" Grid.Column="1" FontWeight="SemiBold" Text="-" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </ScrollViewer>

                                <!-- Export Tab Content -->
                                <ScrollViewer x:Name="SpriteExportTabPanel" VerticalScrollBarVisibility="Auto" Padding="0,0,0,0" Visibility="Collapsed">
                                    <Grid ColumnSpacing="12" RowSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Padding="16"
                                            Background="{StaticResource WinUiPanelBackgroundAltBrush}"
                                            BorderBrush="{StaticResource WinUiPanelStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel Spacing="12">
                                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Export sprite" />
                                                <TextBlock
                                                    x:Name="SpriteExportSummaryText"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="Export selected frame or every texture frame as PNG."
                                                    TextWrapping="Wrap" />
