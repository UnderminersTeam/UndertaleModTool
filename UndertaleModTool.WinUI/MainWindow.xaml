<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="UndertaleModTool_WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UndertaleModTool_WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="UndertaleModTool.WinUI"
    mc:Ignorable="d">
    <Grid Background="{StaticResource WinUiShellBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TitleBar
            x:Name="AppTitleBar"
            Grid.Row="0"
            Height="36"
            IsTabStop="False"
            Padding="10,0,150,0"
            Background="{StaticResource WinUiShellBackgroundBrush}"
            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
            Title="">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>
        <Frame
            x:Name="RootFrame"
            Grid.Row="1" />
    </Grid>
</Window>
